Algoritmo contar
	//Declaro las variables
	Definir contador Como Entero
	Definir tope Como Entero
	
	//Inicializamos las variables
	contador<-1
	Escribir "Indica el número hasta el que quieres que cuente:"
	Leer tope
	
	//Ejecutamos el bucle
	Mientras contador<=tope Hacer
		Escribir contador
		contador <- contador+1
	Fin Mientras
	
FinAlgoritmo
